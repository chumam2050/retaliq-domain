# Domain helper service configuration
# Requests must include the X-Api-Key header matching RETALIQ_API_KEY
RETALIQ_API_KEY=replace-with-secret
# Comma-separated list of client IP addresses permitted to POST to /hosts
RETALIQ_ALLOWED_IPS=127.0.0.1,172.17.0.1
# Optional custom port (defaults to 8888)
#PORT=8888
